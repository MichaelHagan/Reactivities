# Ignore compiled output and intermediate files
bin/
obj/

# Ignore NuGet package directories
*.nupkg
/packages/

# Ignore Visual Studio files
.vs/
*.suo
*.user
*.ncrunch*
*.sln.docstates

# Ignore Resharper files
_ReSharper*/
*.resharper

